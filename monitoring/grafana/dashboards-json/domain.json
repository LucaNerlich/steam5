{
  "uid": "steam5-domain",
  "title": "Steam5 — Domain",
  "tags": ["steam5", "domain", "game"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "Application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": {"query": "label_values(jvm_memory_used_bytes, application)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "definition": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {"text": "steam5", "value": "steam5"},
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Today's picks generated",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 1}, {"color": "green", "value": 5}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none"},
      "targets": [{"refId": "A", "expr": "steam5_daily_picks_last_success_size{application=\"$app\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 2, "type": "stat", "title": "Time since last successful generation",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 86400}, {"color": "red", "value": 93600}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [{"refId": "A", "expr": "time() - steam5_daily_picks_last_success_epoch_seconds{application=\"$app\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 3, "type": "stat", "title": "Reviews coverage",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.5}, {"color": "green", "value": 0.8}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [{"refId": "A", "expr": "steam5_app_reviews_coverage_ratio{application=\"$app\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 4, "type": "stat", "title": "Details coverage",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.5}, {"color": "green", "value": 0.8}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [{"refId": "A", "expr": "steam5_app_details_coverage_ratio{application=\"$app\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Steam API request rate by outcome",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 30, "stacking": {"mode": "normal", "group": "A"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"refId": "A", "expr": "sum by (outcome) (rate(steam_api_requests_total{application=\"$app\"}[5m]))", "legendFormat": "{{outcome}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 6, "type": "timeseries", "title": "Steam API request rate by endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"refId": "A", "expr": "sum by (endpoint) (rate(steam_api_requests_total{application=\"$app\"}[5m]))", "legendFormat": "{{endpoint}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Steam API 429 rate-limit hits",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 20}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.01}]}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"refId": "A", "expr": "sum by (endpoint) (rate(steam_api_rate_limit_hits_total{application=\"$app\"}[5m]))", "legendFormat": "{{endpoint}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 8, "type": "timeseries", "title": "Steam API latency (avg 5m, by endpoint)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"refId": "A", "expr": "sum by (endpoint) (rate(steam_api_request_duration_seconds_sum{application=\"$app\"}[5m])) / clamp_min(sum by (endpoint) (rate(steam_api_request_duration_seconds_count{application=\"$app\"}[5m])), 1e-9)", "legendFormat": "{{endpoint}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 9, "type": "timeseries", "title": "Steam API rate-limiter wait time (avg 5m)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"refId": "A", "expr": "rate(steam_api_rate_limiter_wait_seconds_sum{application=\"$app\"}[5m]) / clamp_min(rate(steam_api_rate_limiter_wait_seconds_count{application=\"$app\"}[5m]), 1e-9)", "legendFormat": "avg wait", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 10, "type": "timeseries", "title": "Ingestion freshness — oldest / newest review age",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"refId": "A", "expr": "steam5_reviews_oldest_age_seconds{application=\"$app\"}", "legendFormat": "oldest", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"refId": "B", "expr": "steam5_reviews_newest_age_seconds{application=\"$app\"}", "legendFormat": "newest", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Index size",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"refId": "A", "expr": "steam5_app_index_size{application=\"$app\"}", "legendFormat": "apps indexed", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 12, "type": "timeseries", "title": "Guesses persisted (5m rate, by outcome)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 80, "stacking": {"mode": "normal", "group": "A"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "sum"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"refId": "A", "expr": "sum by (outcome) (rate(steam5_guesses_total{application=\"$app\"}[5m]))", "legendFormat": "{{outcome}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 13, "type": "stat", "title": "Correct-guess ratio (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "decimals": 2}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [{"refId": "A", "expr": "sum(increase(steam5_guesses_total{application=\"$app\", outcome=\"correct\"}[24h])) / clamp_min(sum(increase(steam5_guesses_total{application=\"$app\"}[24h])), 1)", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 14, "type": "stat", "title": "Total guesses (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [{"refId": "A", "expr": "sum(increase(steam5_guesses_total{application=\"$app\"}[24h]))", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 15, "type": "stat", "title": "Picks days recorded",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [{"refId": "A", "expr": "steam5_picks_distinct_days{application=\"$app\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    },
    {
      "id": 16, "type": "stat", "title": "Latest picks date",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "dateTimeAsIso"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "text": {}},
      "targets": [{"refId": "A", "expr": "steam5_picks_latest_date_epoch_seconds{application=\"$app\"} * 1000", "datasource": {"type": "prometheus", "uid": "prometheus"}}]
    }
  ]
}
